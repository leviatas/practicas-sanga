# ============================================================================
# Variables de entorno de Prácticas Sanga
# Copiá este archivo a `.env` (ignorado por git) y completá lo que necesites.
# `.env` también lo gestiona ./prod.sh automáticamente.
# ============================================================================

# Puerto de publicación local. ./prod.sh lo escribe/actualiza solo
# (usa este valor o busca uno libre si está ocupado).
PORT=8080

# Token del túnel de Cloudflare (opcional).
# Si lo completás, ./prod.sh levanta también el servicio "cloudflared" y
# expone la app a internet a través del túnel.
# Dónde obtenerlo: Cloudflare Zero Trust > Networks > Tunnels > (tu túnel) >
#   Install connector > se muestra el token (la cadena larga tras "--token").
# En el panel del túnel, configurá el public hostname apuntando al servicio
# interno:  http://web:80
CLOUDFLARED_TOKEN=
